<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ListView?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.Pane?>

<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.TextField?>

<AnchorPane id="mainAnchorPane" fx:id="mainAnchorPane" maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity"
            minWidth="-Infinity" prefHeight="800.0" prefWidth="1280.0" xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1" fx:controller="yourmusic.Controller">
        <Pane fx:id="mainPane" prefHeight="330.0" prefWidth="200.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
                <Button fx:id="btnFolder" layoutX="5.0" layoutY="5.0" mnemonicParsing="false" onAction="#btnFolder" prefHeight="30.0" prefWidth="350.0" text="Folder"/>
                <TextField fx:id="fieldSearch" layoutX="5.0" layoutY="40.0" prefHeight="30.0" prefWidth="350.0" promptText="Search"/>
                <ListView fx:id="listView" layoutX="5.0" layoutY="70.0" prefHeight="400.0" prefWidth="350.0"/>

                <Slider fx:id="timeLineMusic" layoutX="40.0" layoutY="480.0" prefHeight="24.0" prefWidth="280.0"/>
                <Label fx:id="labelTimeStart" layoutX="7.0" layoutY="482.0" text="Label"/>
                <Label fx:id="labelTimeEnd" layoutX="325.0" layoutY="482.0" text="Label"/>

                <ToggleButton fx:id="btnRandomMusic"   layoutX="94.0" layoutY="528.0" prefWidth="20.0" prefHeight="20.0" mnemonicParsing="false"/>
                <Button       fx:id="btnPreviousMusic" layoutX="132.0" layoutY="528.0" prefWidth="30.0" prefHeight="30.0" mnemonicParsing="false"/>
                <Button       fx:id="btnPauseUnpause"  layoutX="160.0" layoutY="518.0" prefWidth="20.0" prefHeight="20.0" mnemonicParsing="false"/>
                <Button       fx:id="btnNextMusic"     layoutX="210.0" layoutY="528.0" prefWidth="30.0" prefHeight="30.0" mnemonicParsing="false"/>
                <ToggleButton fx:id="btnRepeatMusic"   layoutX="248.0" layoutY="528.0" prefWidth="20.0" prefHeight="20.0" mnemonicParsing="false"/>
                <Slider       fx:id="volumeMusic"      layoutX="105.0" layoutY="565.0"   prefWidth="150.0" onMouseReleased="#changeVolume"/>
        </Pane>
</AnchorPane>

